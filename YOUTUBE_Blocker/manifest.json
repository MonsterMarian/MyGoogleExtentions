{
  "manifest_version": 3,
  "name": "YouTube Goal Blocker",
  "version": "1.0",
  "description": "Blokuje YouTube videa, dokud si nezdůvodníš, proč je chceš vidět.",
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube SOUDCE",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
